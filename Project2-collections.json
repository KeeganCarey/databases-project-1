// COLLECTION 1: students
// This stores all the students in the system.
// Instead of having separate tables for sessions, feedback, and industries,
// we just put everything inside the student document.

{
  "_id": "auto-generated by MongoDB",
  "first_name": "Maya",
  "last_name": "Patel",
  "email": "maya.patel@university.edu",
  "major": "Computer Science",
  "graduation_year": 2026,
  "is_active": true, // set to false to disable the student

  // list of industries the student is interested in
  // this replaces the Student_industry join table from the relational model
  "industries": [
    {
      "industry_name": "Software Engineering",
      "description": "Building software systems"
    },
    {
      "industry_name": "Data Science",
      "description": "Analyzing data"
    }
  ],

  // list of sessions the student has had or requested
  // each session can also have feedback inside it
  "sessions": [
    {
      "session_id": 1,
      "session_date": "2025-11-10",
      "duration_minutes": 45,
      "status": "completed", // can be: pending, completed, or cancelled
      "topic": "Resume review",
      "mentor_name": "James Torres", // stored here so we dont need an extra lookup

      // feedback is stored inside the session
      // it will be null until the student submits it
      "feedback": {
        "rating": 5,
        "comment": "Really helpful session!",
        "submitted_at": "2025-11-10T15:30:00Z"
      }
    },
    {
      "session_id": 2,
      "session_date": "2026-01-20",
      "duration_minutes": 30,
      "status": "pending",
      "topic": "Career advice",
      "mentor_name": "James Torres",
      "feedback": null // not submitted yet
    }
  ]
}


// COLLECTION 2: mentors
// This stores all the mentors in the system.
// Industries are embedded just like in students.
// Sessions here are just a short summary so the mentor can see their history.
// The full session details live inside the student document.

{
  "_id": "auto-generated by MongoDB",
  "first_name": "James",
  "last_name": "Torres",
  "email": "james.torres@techcorp.com",
  "company": "TechCorp",
  "job_title": "Senior Software Engineer",
  "years_experience": 8,
  "is_active": true, // set to false to hide mentor from search results

  // industries the mentor works in
  // replaces the Mentor_industry join table from the relational model
  "industries": [
    {
      "industry_name": "Software Engineering",
      "description": "Building software systems"
    }
  ],

  // short summary of sessions this mentor has done
  // we only store the basic info here, not the full details
  "sessions": [
    {
      "session_id": 1,
      "student_name": "Maya Patel",
      "session_date": "2025-11-10",
      "status": "completed"
    }
  ]
}